# Copie ce fichier en ".env" (à la racine du projet) et remplis les deux
# valeurs avec celles de ton projet Supabase :
# Dashboard Supabase -> Project Settings -> API
#   - "Project URL"      -> VITE_SUPABASE_URL
#   - "anon public" key  -> VITE_SUPABASE_ANON_KEY

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mesure d'audience (facultatif) ──────────────────────────────────────
# Laisse vide pour désactiver complètement GA4/Clarity (aucun script ne sera
# chargé, aucune erreur ne sera levée). Voir docs/analytics.md pour la
# procédure de création de ces identifiants.
#   Dashboard GA4      -> Admin -> Data Streams -> ton flux Web -> Measurement ID
#   Dashboard Clarity   -> Settings -> Setup -> Project ID (dans le snippet fourni)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_CLARITY_PROJECT_ID=xxxxxxxxxx

# Coupe-circuit global : passe à "false" pour désactiver tout envoi
# d'événement (GA4 + Clarity), même si les identifiants ci-dessus sont
# renseignés. Utile pour un environnement de préproduction par exemple.
VITE_ANALYTICS_ENABLED=true

# Force l'envoi des événements en développement local (npm run dev).
# Par défaut, aucun événement n'est envoyé en local : seul le mode debug
# console (VITE_ANALYTICS_DEBUG) est actif. Ne mets "true" ici que pour
# tester une intégration GA4/Clarity en conditions réelles depuis ta machine.
VITE_ANALYTICS_FORCE_LOCAL=false

# Affiche dans la console les événements qui seraient envoyés
# ([Analytics Debug] game_started {...}), sans jamais rien envoyer en plus.
# Actif par défaut en développement (npm run dev), inactif en production.
VITE_ANALYTICS_DEBUG=true
